@thesis{ullrich_simple_2016,
	title = {Simple Verification of Rust Programs via Functional Purification},
	url = {https://pp.ipd.kit.edu/uploads/publikationen/ullrich16masterarbeit.pdf},
	abstract = {Imperative programming, and aliasing in particular, represents a major
obstacle in formally reasoning about everyday code. By utilizing restrictions
the imperative programming language Rust imposes on mutable aliasing, we
present a scheme for shallowly embedding a substantial part of the Rust lan-
guage into the purely functional language of the Lean theorem prover. We
use this scheme to verify the correctness of real-world examples of Rust code
without the need for special semantics or logics. We furthermore show the
extensibility of our transformation by incorporating an analysis of asymp-
totic runtimes.},
	pagetotal = {65},
	institution = {Karlsruhe Institute of Technology},
	type = {phdthesis},
	author = {Ullrich, Sebastian},
	date = {2016},
	langid = {english},
}

